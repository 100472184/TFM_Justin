# Local-only secrets for LLM providers (never commit real keys).
# Copy this file to `.env.local` in your Kali repo and fill values.
#
# For Ollama Cloud (recommended for keeping model alias ollama/qwen2.5:7b):
# - Create API key in ollama.com
# - Keep OLLAMA_API_BASE as https://ollama.com
# - OLLAMA_API_KEY will be mapped to LLM_API_KEY automatically by the script.
#
# For local Ollama, comment OLLAMA_API_BASE and keep localhost values in your shell.

OLLAMA_API_KEY=replace_me
OLLAMA_API_BASE=https://ollama.com

# Optional explicit value (if you prefer):
# LLM_API_KEY=replace_me

# Optional runtime tuning:
LLM_TIMEOUT=300
LLM_NUM_RETRIES=4
