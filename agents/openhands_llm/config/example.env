# OpenHands LLM Pipeline Configuration
# Copy to .env and customize for your environment


# ============================================================================
# Google Vertex AI / Gemini (DEFAULT - used in thesis baseline)
# ============================================================================
# Requires:
#   1. gcloud auth application-default login
#   2. Set your GCP project ID below

LLM_MODEL=vertex_ai/gemini-2.0-flash-001
LLM_PROJECT=your-gcp-project-id-here
LLM_LOCATION=us-central1
LLM_TIMEOUT=120
LLM_NUM_RETRIES=3


# ============================================================================
# QWEN via Ollama
# ============================================================================
# 1. Install Ollama: https://ollama.ai/download
# 2. Pull model: ollama pull qwen2.5:7b   (or qwen2.5:14b)
# 3. Run server: ollama serve (default port 11434)

# LLM_MODEL=ollama/qwen2.5:7b
# LLM_MODEL=ollama/qwen2.5:14b
# LLM_BASE_URL=http://localhost:11434
# LLM_TIMEOUT=120
# LLM_NUM_RETRIES=3


# ============================================================================
# LLaMA via Ollama
# ============================================================================
# Pull model: ollama pull llama3.1:8b   (or llama3.1:70b)

# LLM_MODEL=ollama/llama3.1:8b
# LLM_MODEL=ollama/llama3.1:70b
# LLM_BASE_URL=http://localhost:11434
# LLM_TIMEOUT=120
# LLM_NUM_RETRIES=3


# ============================================================================
# Mistral via Ollama
# ============================================================================
# Pull model: ollama pull mistral:7b   (or mistral-nemo:12b)

# LLM_MODEL=ollama/mistral:7b
# LLM_MODEL=ollama/mistral-nemo:12b
# LLM_BASE_URL=http://localhost:11434
# LLM_TIMEOUT=120
# LLM_NUM_RETRIES=3


# ============================================================================
# OpenAI GPT (Commercial API)
# ============================================================================
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_TIMEOUT=60
# LLM_NUM_RETRIES=3


# ============================================================================
# Anthropic Claude (Commercial API)
# ============================================================================
# LLM_MODEL=claude-3-5-sonnet-20240620
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_TIMEOUT=60
# LLM_NUM_RETRIES=3


# ============================================================================
# Custom LLM Provider (e.g., local vLLM, text-generation-webui, etc.)
# ============================================================================
# LLM_MODEL=custom/your-model-name
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=optional-if-needed
# LLM_TIMEOUT=120
# LLM_NUM_RETRIES=3


# ============================================================================
# Advanced Settings (optional)
# ============================================================================
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048
# LLM_TOP_P=0.9
